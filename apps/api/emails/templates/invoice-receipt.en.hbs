<p>Thank you for your payment, {{name}} !</p>

<p>Here is your invoice receipt:</p>

<div style="background-color: #f0f0f0; padding: 15px; border-radius: 4px; margin: 20px 0;">
  <p style="margin: 0 0 10px 0;"><strong>Invoice number:</strong> {{invoiceNumber}}</p>
  <p style="margin: 0 0 10px 0;"><strong>Dates:</strong> {{formatDate checkIn locale}} - {{formatDate checkOut locale}}</p>
  <p style="margin: 0 0 10px 0;"><strong>Payment date:</strong> {{formatDate paymentDate locale}}</p>
</div>

<p><strong>Invoice details:</strong></p>

<table style="width: 100%; border-collapse: collapse; margin: 20px 0;">
  <tr style="border-bottom: 1px solid #ddd;">
    <th style="text-align: left; padding: 8px; background-color: #f0f0f0;">Description</th>
    <th style="text-align: right; padding: 8px; background-color: #f0f0f0;">Amount</th>
  </tr>
  {{#each lineItems}}
  <tr style="border-bottom: 1px solid #ddd;">
    <td style="padding: 8px;">{{this.description}}</td>
    <td style="text-align: right; padding: 8px;">{{money this.amount}}</td>
  </tr>
  {{/each}}
  <tr style="border-bottom: 2px solid #333;">
    <td style="padding: 8px; font-weight: bold;">Subtotal</td>
    <td style="text-align: right; padding: 8px; font-weight: bold;">{{money subtotal}}</td>
  </tr>
  <tr style="border-bottom: 1px solid #ddd;">
    <td style="padding: 8px;">Accommodation tax (3.5%)</td>
    <td style="text-align: right; padding: 8px;">{{money accommodationTax}}</td>
  </tr>
  <tr style="border-bottom: 1px solid #ddd;">
    <td style="padding: 8px;">GST (5%)</td>
    <td style="text-align: right; padding: 8px;">{{money tps}}</td>
  </tr>
  <tr style="border-bottom: 2px solid #333;">
    <td style="padding: 8px;">QST (9.975%)</td>
    <td style="text-align: right; padding: 8px;">{{money tvq}}</td>
  </tr>
  <tr>
    <td style="padding: 8px; font-weight: bold; font-size: 16px;">Total</td>
    <td style="text-align: right; padding: 8px; font-weight: bold; font-size: 16px;">{{money total}}</td>
  </tr>
</table>

<p>Thank you for your business.</p>

<p>Best regards,<br/>
The Vieux Pont team</p>
