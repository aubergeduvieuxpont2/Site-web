<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{subject}}</title>
  <style>
    body { margin: 0; padding: 0; font-family: "IBM Plex Sans", Arial, Helvetica, sans-serif; }
  </style>
</head>
<body style="margin: 0; padding: 0; background-color: #f7f9fb;">
  <table width="100%" cellpadding="0" cellspacing="0" style="width: 100%; background-color: #f7f9fb;">
    <tr>
      <td align="center" style="padding: 20px 0;">
        <table width="600" cellpadding="0" cellspacing="0" style="max-width: 600px; background-color: white; border-collapse: collapse;">
          {{> header}}
          <tr>
            <td style="padding: 20px; color: #2d3133; font-size: 14px; line-height: 1.6;">
              {{> body}}
            </td>
          </tr>
          {{> footer}}
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
