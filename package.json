{
  "name": "site-web",
  "private": true,
  "version": "0.0.0",
  "description": "Full-stack web application on Cloudflare (Workers + D1).",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace apps/web",
    "dev:api": "npm run dev --workspace apps/api",
    "build:web": "npm run build --workspace apps/web",
    "deploy:web": "npm run deploy --workspace apps/web",
    "deploy:api": "npm run deploy --workspace apps/api",
    "dev:hubspot": "npm run dev --workspace apps/hubspot",
    "deploy:hubspot": "npm run deploy --workspace apps/hubspot",
    "dev:email-ingest": "npm run dev --workspace apps/email-ingest",
    "deploy:email-ingest": "npm run deploy --workspace apps/email-ingest",
    "test": "npm test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:migrate": "npm run db:migrate --workspace apps/api"
  },
  "engines": {
    "node": ">=22"
  }
}
