# Local development environment for the API and HubSpot gateway Workers.
# Copy this file to `.dev.env` (gitignored) and fill in real values.
# The API `dev` script loads it via `wrangler dev --env-file ../../.dev.env`,
# and `npm run db:migrate` reads DB_CONN from here as well.
# The HubSpot gateway `dev` script loads the same file via `wrangler dev --env-file ../../.dev.env`.

# Neon Postgres connection string. Use the POOLED connection string from the
# Neon dashboard (host contains "-pooler"), with sslmode=require.
DB_CONN=postgresql://USER:PASSWORD@ep-xxxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require

# HubSpot private app token (required for apps/hubspot).
# Create a private app in HubSpot and copy its access token here.
HUBSPOT_TOKEN=

# Optional HubSpot pipeline/stage identifiers for deal creation.
# If unset, deals are created without an explicit pipeline or deal stage.
HUBSPOT_PIPELINE_ID=
HUBSPOT_DEALSTAGE_ID=

# Optional HubSpot timeline event template ID for timeline.event ops.
# If unset, timeline events must supply templateId in each payload.
HUBSPOT_TIMELINE_EVENT_TEMPLATE_ID=

# Inter-service shared secrets (X-Internal-Auth). Two SEPARATE secrets so a
# leak of one hop never compromises the other. Set the same value on both
# Workers that share each secret (as Worker secrets in production).
#   - GATEWAY_AUTH_SECRET: API Worker <-> HubSpot gateway (/ops/*).
#   - INTERNAL_OTA_SECRET: email-ingest Worker <-> API (/internal/ota-bookings).
# An unset/empty secret fails closed (all internal calls are rejected with 401).
GATEWAY_AUTH_SECRET=
INTERNAL_OTA_SECRET=

# email-ingest dev-environment-only body secret token (unused in production;
# reserved for a DKIM-authenticated operator test path).
DEV_INGEST_SECRET=

# Admin bootstrap seed email. Used by migration 0006_admin_seed.sql to promote
# one user to role='admin'. Must be set BEFORE running `npm run db:migrate` in
# production so the seed takes effect. If unset, the seed is a harmless no-op.
# Also used by DB_CONN-backed auth queries (register, login, session validation).
ADMIN_EMAIL=

# Stripe integration (apps/api). Required for creating hosted invoices and
# verifying webhook signatures. Never put these in apps/web.
# STRIPE_SECRET_KEY: Stripe secret key (starts with sk_test_ or sk_live_).
# STRIPE_WEBHOOK_SECRET: Webhook signing secret from the Stripe dashboard
#   (starts with whsec_). Used by POST /api/webhooks/stripe to verify signatures
#   via stripe.webhooks.constructEventAsync.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
