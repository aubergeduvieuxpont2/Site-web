# Local development environment for the API and HubSpot gateway Workers.
# Copy this file to `.dev.env` (gitignored) and fill in real values.
# The API `dev` script loads it via `wrangler dev --env-file ../../.dev.env`,
# and `npm run db:migrate` reads DB_CONN from here as well.
# The HubSpot gateway `dev` script loads the same file via `wrangler dev --env-file ../../.dev.env`.

# Neon Postgres connection string. Use the POOLED connection string from the
# Neon dashboard (host contains "-pooler"), with sslmode=require.
DB_CONN=postgresql://USER:PASSWORD@ep-xxxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require

# HubSpot private app token (required for apps/hubspot).
# Create a private app in HubSpot and copy its access token here.
HUBSPOT_TOKEN=

# Optional HubSpot pipeline/stage identifiers for deal creation.
# If unset, deals are created without an explicit pipeline or deal stage.
HUBSPOT_PIPELINE_ID=
HUBSPOT_DEALSTAGE_ID=

# Optional HubSpot timeline event template ID for timeline.event ops.
# If unset, timeline events must supply templateId in each payload.
HUBSPOT_TIMELINE_EVENT_TEMPLATE_ID=
